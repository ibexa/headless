{
    "name": "ibexa/headless",
    "type": "metapackage",
    "license": "proprietary",
    "description": "A meta package for installing Ibexa DXP Headless edition",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://updates.ibexa.co"
        }
    ],
    "replace": {
        "ibexa/content": "*"
    },
    "require": {
        "php": ">=8.3",
        "ibexa/oss": "~6.0.x-dev",
        "ibexa/collaboration": "~6.0.x-dev",
        "ibexa/connect": "~6.0.x-dev",
        "ibexa/measurement": "~6.0.x-dev",
        "ibexa/migrations": "~6.0.x-dev",
        "ibexa/image-editor": "~6.0.x-dev",
        "ibexa/oauth2-client": "~6.0.x-dev",
        "ibexa/installer": "~6.0.x-dev",
        "ibexa/product-catalog": "~6.0.x-dev",
        "ibexa/product-catalog-date-time-attribute": "~6.0.x-dev",
        "ibexa/product-catalog-symbol-attribute": "~6.0.x-dev",
        "ibexa/seo": "~6.0.x-dev",
        "ibexa/scheduler": "~6.0.x-dev",
        "ibexa/calendar": "~6.0.x-dev",
        "ibexa/connector-dam": "~6.0.x-dev",
        "ibexa/connector-ai": "~6.0.x-dev",
        "ibexa/connector-openai": "~6.0.x-dev",
        "ibexa/elasticsearch": "~6.0.x-dev",
        "ibexa/fastly": "~6.0.x-dev",
        "ibexa/personalization": "~6.0.x-dev",
        "ibexa/version-comparison": "~6.0.x-dev",
        "ibexa/workflow": "~6.0.x-dev",
        "ibexa/taxonomy": "~6.0.x-dev",
        "ibexa/tree-builder": "~6.0.x-dev",
        "ibexa/content-tree": "~6.0.x-dev",
        "ibexa/image-picker": "~6.0.x-dev",
        "ibexa/share": "~6.0.x-dev",
        "ibexa/site-context": "~6.0.x-dev",
        "ibexa/headless-assets": "~6.0.0@alpha",
        "ibexa/app-switcher": "~6.0.x-dev",
        "gregwar/captcha-bundle": "^2.1"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "6.0.x-dev"
        }
    }
}
